# k3s server configuration
# Copy to .env and fill in your values before running install-server.sh.

# ------- Node identity --------------------------------------------------------
# IP of THIS server node — used as --node-ip and written into the API TLS cert.
NODE_IP=192.168.1.100

# IP of the FIRST server node — used as the HA join endpoint by other servers.
# On a single-node cluster set this to the same value as NODE_IP.
FIRST_SERVER_IP=192.168.1.100

# Version pin — always pin in production.
# Find releases at: https://github.com/k3s-io/k3s/releases
K3S_VERSION=v1.35.4+k3s1

# ------- Networking -----------------------------------------------------------
CLUSTER_CIDR=10.42.0.0/16
SERVICE_CIDR=10.43.0.0/16

# Extra IPs or hostnames added to the API server TLS cert (SAN).
# Add your load-balancer VIP or DNS name so remote kubectl works.
# Comma-separated. Example: "lb.example.com,10.0.0.10"
EXTRA_SANS=""

# ------- Storage --------------------------------------------------------------
DATA_DIR=/var/lib/rancher/k3s

# Set to true only after Longhorn is installed and PVCs are migrated.
# Passes --disable local-storage to the k3s server.
DISABLE_LOCAL_STORAGE=false

# ------- etcd snapshots -------------------------------------------------------
ETCD_SNAPSHOT_SCHEDULE_CRON="0 */6 * * *"   # every 6 hours
ETCD_SNAPSHOT_RETENTION=5                    # number of snapshots to keep
# ETCD_S3=true
# ETCD_S3_ENDPOINT=s3.example.com
# ETCD_S3_BUCKET=k3s-etcd-backups
# ETCD_S3_ACCESS_KEY=
# ETCD_S3_SECRET_KEY=

# ------- Security -------------------------------------------------------------
# Encrypt Kubernetes secrets at rest using AES-CBC.
SECRETS_ENCRYPTION=true

# ------- Kubelet tuning -------------------------------------------------------
EVICTION_HARD_MEMORY=200Mi
EVICTION_SOFT_MEMORY=300Mi
EVICTION_SOFT_GRACE=30s
