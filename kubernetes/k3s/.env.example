# k3s production configuration
# Copy this file to .env and fill in your values before running any script.
# All Ansible playbooks and install scripts source this file.

# ------- Cluster identity -----------------------------------------------------
# IP of the FIRST server node (used as the HA join endpoint by other servers/agents)
FIRST_SERVER_IP=192.168.1.100

# Version pin — always pin in production. Find releases at:
# https://github.com/k3s-io/k3s/releases
K3S_VERSION=v1.35.4+k3s1

# ------- Networking ----------------------------------------------------------
CLUSTER_CIDR=10.42.0.0/16
SERVICE_CIDR=10.43.0.0/16

# Extra IPs or hostnames written into the API server TLS certificate.
# Add your load-balancer VIP or DNS name here so remote kubectl works.
# Comma-separated. Example: "lb.example.com,10.0.0.10"
EXTRA_SANS=""

# ------- Storage --------------------------------------------------------------
DATA_DIR=/var/lib/rancher/k3s

# local-path provisioner ships with k3s and is kept enabled by default.
# Set to true only when you are ready to switch to Longhorn permanently
# (run helm/set-default-storageclass.sh and docs/migrate-to-longhorn.md first).
DISABLE_LOCAL_STORAGE=false

# ------- etcd snapshots -------------------------------------------------------
# Snapshots are saved to DATA_DIR/server/db/snapshots by default.
# Set ETCD_S3=true and fill in the S3 block to ship snapshots off-node.
ETCD_SNAPSHOT_SCHEDULE_CRON="0 */6 * * *"   # every 6 hours
ETCD_SNAPSHOT_RETENTION=5                    # number of snapshots to keep
# ETCD_S3=true
# ETCD_S3_ENDPOINT=s3.example.com
# ETCD_S3_BUCKET=k3s-etcd-backups
# ETCD_S3_ACCESS_KEY=
# ETCD_S3_SECRET_KEY=

# ------- Security -------------------------------------------------------------
# Encrypt Kubernetes secrets at rest using AES-CBC.
SECRETS_ENCRYPTION=true

# ------- Tuning for small hosts -----------------------------------------------
# Kubelet eviction thresholds — adjust if your nodes have very little RAM.
EVICTION_HARD_MEMORY=200Mi   # hard evict pods when available memory drops below
EVICTION_SOFT_MEMORY=300Mi   # soft evict (with grace period)
EVICTION_SOFT_GRACE=30s
