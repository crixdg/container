# k3s agent configuration
# Copy to .env and fill in your values before running install-agent.sh.
# K3S_SERVER_URL and K3S_TOKEN must also be exported in your shell — see below.

# ------- Node identity --------------------------------------------------------
# IP of THIS agent node.
NODE_IP=192.168.1.110

# Version pin — must match the server version.
# Find releases at: https://github.com/k3s-io/k3s/releases
K3S_VERSION=v1.35.4+k3s1

# ------- Storage --------------------------------------------------------------
DATA_DIR=/var/lib/rancher/k3s

# ------- Kubelet tuning -------------------------------------------------------
EVICTION_HARD_MEMORY=200Mi
EVICTION_SOFT_MEMORY=300Mi
EVICTION_SOFT_GRACE=30s

# ------- Join credentials (export in shell, do not commit) --------------------
# K3S_SERVER_URL=https://<FIRST_SERVER_IP>:6443
# K3S_TOKEN=<contents of /var/lib/rancher/k3s/server/node-token on the server>
