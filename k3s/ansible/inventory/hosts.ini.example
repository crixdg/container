# k3s cluster inventory
# Replace IPs and usernames with your actual values.

[k3s_servers] # Server nodes (masters) — run control plane and etcd. Can also run workloads, but not recommended for production.
# First server — bootstraps the cluster (cluster-init). Must be listed first.
server-01 ansible_host=192.168.1.100 ansible_user=root

# Additional server nodes (HA — 3 servers gives etcd quorum).
server-02 ansible_host=192.168.1.101 ansible_user=root
server-03 ansible_host=192.168.1.102 ansible_user=root

[k3s_agents] # Agent nodes (workers) — can be added/removed dynamically.
agent-01 ansible_host=192.168.1.110 ansible_user=root
agent-02 ansible_host=192.168.1.111 ansible_user=root
agent-03 ansible_host=192.168.1.112 ansible_user=root

[k3s_cluster:children]
k3s_servers
k3s_agents
