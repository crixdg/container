# Cilium component — required variables
# Copy to .env and fill in values for your cluster.

# IP address of the Kubernetes API server.
# Used by Cilium agents to reach the API server directly (bypasses kube-proxy).
API_SERVER_IP=<api-server-ip>

# Port of the Kubernetes API server (default: 6443).
API_SERVER_PORT=6443

# Pod network CIDR. Must match --cluster-cidr (k3s) or podSubnet (kubeadm).
# Cilium IPAM allocates per-node subnets from this range.
POD_NETWORK_CIDR=10.42.0.0/16

# Unique cluster name. Used for identity scoping and Hubble UI labelling.
# Required if you plan to use clustermesh or share a Prometheus/Hubble relay.
CLUSTER_NAME=prod-01

# Hostname for the Hubble UI ingress.
HUBBLE_UI_HOST=hubble-ui.<api-server-ip>.nip.io
